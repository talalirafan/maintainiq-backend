# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/maintainiq

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=maintainiq

# Gemini AI (backend only — never expose to frontend)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# SMTP / Nodemailer
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="MaintainIQ <noreply@maintainiq.local>"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Uploads
MAX_UPLOAD_SIZE_MB=10

# Cron
MAINTENANCE_REMINDER_CRON=0 8 * * *

# Bootstrap admin (created automatically when users collection is empty)
BOOTSTRAP_ADMIN_NAME=MaintainIQ Admin
BOOTSTRAP_ADMIN_EMAIL=admin@maintainiq.local
BOOTSTRAP_ADMIN_PASSWORD=Admin123!
